{
  "name": "nanoclaw",
  "version": "1.2.14",
  "description": "Personal Claude assistant. Lightweight, secure, customizable.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:electron": "node scripts/build-electron.mjs && electron dist-electron/main.cjs",
    "dev:electron:watch": "node scripts/build-electron.mjs && electron dist-electron/main.cjs",
    "build:electron": "node scripts/build-electron.mjs",
    "dev:assistant": "node scripts/build-assistant.mjs && electron dist-assistant/main.cjs",
    "build:assistant": "node scripts/build-assistant.mjs",
    "package:mac": "npm run build && npm run build:electron && electron-builder --mac",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "setup": "tsx setup/index.ts",
    "auth": "tsx src/whatsapp-auth.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "better-sqlite3": "^11.8.1",
    "cron-parser": "^5.5.0",
    "form-data": "^4.0.5",
    "mysql2": "^3.20.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "ws": "^8.18.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "@vitest/coverage-v8": "^4.0.18",
    "dotenv-cli": "^11.0.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
