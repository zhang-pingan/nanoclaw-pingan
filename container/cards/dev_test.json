{
  "plan_confirm": {
    "pattern": "confirm_revise",
    "header": {
      "title_template": "📋 确认方案后进入开发",
      "color": "green"
    },
    "body_template": "**流程 ID**：{{id}}\n**服务**：{{service}}\n**交付文档**：projects/{{service}}/iteration/{{deliverable}}/plan.md\n\n请选择：\n1) 直接进入开发\n2) 提交修改意见，回到 Plan 重新设计",
    "actions": [
      {
        "id": "approve_dev",
        "label": "✅ 进入开发",
        "type": "primary"
      },
      {
        "id": "cancel",
        "label": "❌ 取消流程",
        "type": "danger"
      }
    ],
    "form": {
      "name": "revision_form",
      "submit_action": {
        "id": "request_revision",
        "label": "✏️ 返回方案修改"
      },
      "fields": [
        {
          "name": "revision_text",
          "label": "修改意见",
          "type": "textarea",
          "placeholder": "如需修改方案，请输入修改意见...",
          "required": true
        }
      ]
    }
  },
  "plan_examine_confirm": {
    "pattern": "confirm_revise",
    "header": {
      "title_template": "📋 确认方案修改或继续开发",
      "color": "orange"
    },
    "body_template": "**流程 ID**：{{id}}\n**服务**：{{service}}\n**交付文档**：projects/{{service}}/iteration/{{deliverable}}/plan.md\n\n请选择：\n1) 直接继续后续流程（进入开发）\n2) 回到 Plan 修改（可填写补充修改意见）",
    "actions": [
      {
        "id": "approve_dev",
        "label": "✅ 继续开发",
        "type": "primary"
      },
      {
        "id": "cancel",
        "label": "❌ 取消流程",
        "type": "danger"
      }
    ],
    "form": {
      "name": "revision_form",
      "submit_action": {
        "id": "request_revision",
        "label": "✏️ 返回方案修改"
      },
      "fields": [
        {
          "name": "revision_text",
          "label": "修改意见",
          "type": "textarea",
          "placeholder": "请输入补充修改意见",
          "required": true
        }
      ]
    }
  },
  "deploy_confirm": {
    "pattern": "info_actions",
    "header": {
      "title_template": "⏳ 确认预发部署",
      "color": "blue"
    },
    "body_template": "**流程 ID**：{{id}}\n**需求**：{{name}}\n**服务**：{{service}}\n**工作分支**：{{work_branch}}\n**交付文档**：{{deliverable}}\n\n请选择是否开始预发部署。",
    "actions": [
      {
        "id": "approve",
        "label": "✅ 开始预发部署",
        "type": "primary"
      },
      {
        "id": "pause",
        "label": "⏸ 暂缓"
      },
      {
        "id": "cancel",
        "label": "❌ 取消流程",
        "type": "danger"
      }
    ]
  },
  "dev_examine_confirm": {
    "pattern": "confirm_revise",
    "header": {
      "title_template": "📋 确认回修或继续后续流程",
      "color": "orange"
    },
    "body_template": "**流程 ID**：{{id}}\n**服务**：{{service}}\n**工作分支**：{{work_branch}}\n**交付文档**：{{deliverable}}\n\n请选择：\n1) 直接继续后续流程\n2) 回到开发修正（可填写补充修改意见）",
    "actions": [
      {
        "id": "approve",
        "label": "✅ 继续后续流程",
        "type": "primary"
      },
      {
        "id": "cancel",
        "label": "❌ 取消流程",
        "type": "danger"
      }
    ],
    "form": {
      "name": "revision_form",
      "submit_action": {
        "id": "request_revision",
        "label": "✏️ 返回开发修正"
      },
      "fields": [
        {
          "name": "revision_text",
          "label": "修改意见",
          "type": "textarea",
          "placeholder": "请输入补充修改意见",
          "required": true
        }
      ]
    }
  },
  "testing_confirm": {
    "pattern": "form_submit",
    "header": {
      "title_template": "🔐 填写 access_token 后开始测试",
      "color": "orange"
    },
    "body_template": "**流程 ID**：{{id}}\n**需求**：{{name}}\n**服务**：{{service}}\n**交付文档**：{{deliverable}}\n\n部署已完成。请先填写接口测试使用的 access_token，系统会在委派测试任务时自动附带该字段。\n\n如本轮测试无需鉴权，也可直接点击“跳过当前节点”。",
    "actions": [
      {
        "id": "skip",
        "label": "⏭ 跳过鉴权直接测试"
      },
      {
        "id": "pause",
        "label": "⏸ 暂缓"
      },
      {
        "id": "cancel",
        "label": "❌ 取消流程",
        "type": "danger"
      }
    ],
    "form": {
      "name": "access_token_form",
      "submit_action": {
        "id": "submit_access_token",
        "label": "🔐 提交 Token 并开始测试",
        "type": "primary"
      },
      "fields": [
        {
          "name": "access_token",
          "label": "Access Token",
          "type": "text",
          "placeholder": "请输入接口测试所需的 access_token",
          "required": true
        }
      ]
    }
  }
}
