TELEGRAM_BOT_TOKEN=

# Claude model (optional, defaults to SDK default)
CLAUDE_MODEL=claude-opus-4-6

# DevOps - Code Repos (default: ~/IdeaProjects)
REPOS_DIR=~/IdeaProjects

# DevOps - SSH key for server access (optional, if different from ~/.ssh/id_rsa)
SSH_KEY_PATH=/path/to/your/ssh/private_key

# DevOps - Jenkins (optional)
JENKINS_URL=https://jenkins.example.com
JENKINS_USER=admin
JENKINS_PASSWORD=your-password

# DevOps - MySQL passwords (one per service)
# Format: MYSQL_PASSWORD_{service_name}=your_password
# Example: MYSQL_PASSWORD_catstory=your_password
